set number
set hls

filetype on
syntax on
filetype plugin indent on

" Global setting: Tab and indentation are 2 spaces
set tabstop=2       " A <Tab> is displayed as 2 spaces
set shiftwidth=2    " Use 2 spaces for each step of (auto)indent
set expandtab       " Convert <Tab> into spaces
set softtabstop=2   " In insert mode, <Tab>/<BS> tab or backsapce counts as 2 spaces


" Automatically remove trailing whitespace before saving
autocmd BufWritePre * :%s/\s\+$//e

set spell
set spelllang=en_us,cjk   " check both English and Chinese


call plug#begin()
Plug 'bfrg/vim-c-cpp-modern', { 'for': ['c', 'cpp'] }
Plug 'vim-autoformat/vim-autoformat'
call plug#end()


augroup cpp_make
  autocmd!
  autocmd FileType cpp setlocal makeprg=clang++\ -std=c++11\ %\ -o\ %<
  autocmd FileType c   setlocal makeprg=clang\ %\ -o\ %<
  autocmd FileType cpp setlocal errorformat=%f:%l:%c:\ %m
  autocmd FileType c   setlocal errorformat=%f:%l:%c:\ %m
augroup END
